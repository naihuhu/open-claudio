# ============================================================================
# open-claudio — environment template
# Copy to `.env` and fill in. NEVER commit real keys to .env.example.
# Priority: config.json > .env > built-in defaults. config.json is the
# authoritative source — a value set there always wins. Variables here only
# FILL BLANKS config.json leaves empty, and seed a fresh config.json on first
# run (no config.json → load .env → write config.json). UI prefs (theme,
# default dark), the DJ-patter/narration switch (default ON) and the default-FM
# switch (default ON) live in config.json under `ui` / `tts.narration` / `fm.default`.
# ============================================================================

# --- AI Studio (auto-injected at runtime) ----------------------------------
# APP_URL: URL where this applet is hosted. AI Studio injects the Cloud Run
#   service URL. Used for self-referential links, OAuth callbacks, API endpoints.
APP_URL="MY_APP_URL"

# --- Custom LLM API (OpenAI-compatible) -------------------------------------
LLM_API_ADDRESS="https://api.openai.com/v1"
LLM_API_KEY=""
LLM_MODEL_NAME="gpt-3.5-turbo"

# CLAUDIO_MAX_INPUT_TOKENS: per-turn budget for the CHAT HISTORY fed to the model
#   (default: 8000). The full conversation is replayed each turn, so old history
#   is trimmed to this budget to avoid overflowing the context window (the system
#   prompt is added separately — this caps history only; the stored thread is
#   untouched). Keep ~8000 for a 16k model; raise it for big-context models
#   (qwen/gemini), e.g. 60000.
CLAUDIO_MAX_INPUT_TOKENS="8000"

# --- Playback behavior ------------------------------------------------------
# FM_DEFAULT: when ON, the app opens straight into 私人 FM (an endless single-track
#   stream) on launch instead of a static playlist. config.json `fm.default` wins;
#   FM_DEFAULT only fills a blank. Accepts 1/true/yes/on or 0/false/no/off. Needs a
#   Netease login — if not logged in, FM quietly turns off and the normal playlist
#   shows. Default: true (on).
# FM_DEFAULT="true"

# --- Dual TTS provider (SPEC «模块 B：TTS 接入» §5, D-18/D-19) ----------------
# Provider auto-selects: if both are configured, FISH WINS. Set TTS_PROVIDER to force one.
# TTS_PROVIDER: "fish" | "doubao"  (leave empty for auto / prefer-fish)
# TTS_PROVIDER=""

# Doubao (火山引擎 语音合成大模型 2.0) — DOUBAO_ prefix (or use the Settings UI fields).
# RESOURCE_ID: seed-tts-2.0 (大模型音色) or seed-icl-2.0 (复刻音色).
DOUBAO_TTS_API_KEY=""
DOUBAO_TTS_RESOURCE_ID="seed-tts-2.0"
DOUBAO_TTS_SPEAKER="zh_male_shenyeboke_uranus_bigtts"

# Fish Audio (s2-pro). API credit is separate from platform plan credits.
# FISH_PROXY: Fish needs a proxy from mainland China (e.g. http://127.0.0.1:7897).
#   Only Fish requests use it; netease/doubao stay direct. Falls back to
#   HTTPS_PROXY / ALL_PROXY if unset.
FISH_API_KEY=""
FISH_TTS_MODEL="s2-pro"
# FISH_TTS_REFERENCE_ID: THE main lever for "电台感". Empty = generic default voice
#   (flat, no radio character). Pick a warm/mellow radio-style voice on fish.audio and
#   paste its voice id, or clone a DJ voice from a 10–30s sample.
FISH_TTS_REFERENCE_ID=""
FISH_PROXY="http://127.0.0.1:7897"
# FISH_SPEED: prosody speed 0.5~2.0; slower (0.85~0.92) reads more like a late-night DJ. Default 0.9.
FISH_SPEED="0.9"
# FISH_TEMPERATURE / FISH_TOP_P: 0~1 expressiveness randomness (Fish default 0.7).
# FISH_TEMPERATURE="0.7"
# FISH_TOP_P="0.7"
# FISH_VOLUME: prosody volume gain in dB (Fish sounds quieter than Doubao; normalize_loudness
#   is off so this actually applies). Default 8; push to 10~12 if still too quiet.
FISH_VOLUME="8"

# --- Storage directories ----------------------------------------------------
# CLAUDIO_DIR: Base directory for persisted data (config.json, chat_history.json,
#   CLAUDIO.md, TASTE.md, music). Defaults to "<home>/.claudio".
# CLAUDIO_MUSIC_DIR: Override where user_session.json / liked_songs.jsonl are stored.
#   Defaults to CLAUDIO_DIR (no separate "music" sub-folder).
CLAUDIO_DIR="./.claudio"
# CLAUDIO_MUSIC_DIR="/path/to/.claudio/music"

# --- Server -----------------------------------------------------------------
# PORT: Port the server listens on (default: 3000).
# HOST: Address the server binds to (default: 0.0.0.0).
# PORT="3000"
# HOST="0.0.0.0"

# --- Logging (Module A / Module B observability) ----------------------------
# LOG_LEVEL: error | warn | info | debug  (default: info). At info, model prompts,
#   tool I/O and music-API I/O are printed. Change at runtime via:
#   POST /api/loglevel {"level":"debug"}.
# LOG_MAX_FIELD: max chars per serialized field before truncation (default: 8000).
LOG_LEVEL="info"
# LOG_MAX_FIELD="8000"

# --- LangSmith tracing (optional) -------------------------------------------
# Set to monitor the agent's prompts, tool calls and event stream.
# LangChain/LangGraph read these automatically. Get a key at https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY="lsv2_pt_xxx"
# LANGSMITH_PROJECT="openclaudio"
